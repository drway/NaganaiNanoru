{
    // 本文件主要定义了通用 UI 的行为和显示内容
    // 可参考文档和示例添加更多您需要的功能
    // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
    // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
    "interface_version": 2,
    "name": "MaaDelta",
    "description": "基于 MaaFramework 构建的智能抢购助手。",
    "contact": "QQ群: 123456789",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MAA!",
    // 填写项目地址和版本号可实现自动更新功能 (请替换为你实际的 GitHub 仓库地址)
    "github": "https://github.com/drway/NaganaiNanoru",
    "version": "1.0.0",
    // Mirror酱为第三方分发服务，新项目默认关闭
    // 若有需要请联系 Mirror酱 开通，直接自行开启是无法使用的
    // "mirrorchyan_rid": "MaaXXX",
    // "mirrorchyan_multiplatform": true,
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "三角洲行动.*",
                // 截图及控制方式，请根据项目实际情况修改
                // 文档: https://maafw.xyz/docs/2.4-ControlMethods
                "screencap": "PrintWindow", // 截图方式
                "mouse": "Seize", // 鼠标控制方式
                "keyboard": "Seize" // 键盘控制方式
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "./agent/main.py"
        ]
    },
    "task": [
        {
            "name": "DeltaStore",
            "label": "DeltaStore（商店购买）",
            "entry": "CheckStatus",
            "description": "检查状态后自动购买",
            "option": [
                "SmartClick设置"
            ]
        }
    ],
    "option": {
        "SmartClick设置": {
            "type": "input",
            "label": "SmartClick点击延迟及对时设置",
            "description": "针对使用SmartClick自定义动作的任务配置随机延迟区间及触发时间。请在任务流水线中将需要此策略的节点命名为 SmartClickNode 或自行在此修改对应的流水线覆盖节点名。",
            "inputs": [
                {
                    "name": "TargetTime",
                    "label": "目标点击时间(留空=由OCR自动推算)",
                    "default": "",
                    "pipeline_type": "string"
                },
                {
                    "name": "JumpTimeEnabled",
                    "label": "启用系统时间跳跃(1开启/0关闭，需管理员权限)",
                    "default": "0",
                    "pipeline_type": "int"
                },
                {
                    "name": "FixedEnabled",
                    "label": "启用固定延迟(1开启/0关闭)",
                    "default": "0",
                    "pipeline_type": "int"
                },
                {
                    "name": "FixedDelay",
                    "label": "固定延迟(ms)",
                    "default": "850",
                    "pipeline_type": "int"
                },
                {
                    "name": "UltraLowEnabled",
                    "label": "超低区间启用(1/0)",
                    "default": "1",
                    "pipeline_type": "int"
                },
                {
                    "name": "UltraLowMin",
                    "label": "超低区间下限",
                    "default": "800",
                    "pipeline_type": "int"
                },
                {
                    "name": "UltraLowMax",
                    "label": "超低区间上限",
                    "default": "820",
                    "pipeline_type": "int"
                },
                {
                    "name": "UltraLowWeight",
                    "label": "超低区间权重",
                    "default": "1",
                    "pipeline_type": "int"
                },
                {
                    "name": "LowEnabled",
                    "label": "低区间启用(1/0)",
                    "default": "1",
                    "pipeline_type": "int"
                },
                {
                    "name": "LowMin",
                    "label": "低区间下限",
                    "default": "820",
                    "pipeline_type": "int"
                },
                {
                    "name": "LowMax",
                    "label": "低区间上限",
                    "default": "840",
                    "pipeline_type": "int"
                },
                {
                    "name": "LowWeight",
                    "label": "低区间权重",
                    "default": "2",
                    "pipeline_type": "int"
                },
                {
                    "name": "MidEnabled",
                    "label": "中区间启用(1/0)",
                    "default": "1",
                    "pipeline_type": "int"
                },
                {
                    "name": "MidMin",
                    "label": "中区间下限",
                    "default": "840",
                    "pipeline_type": "int"
                },
                {
                    "name": "MidMax",
                    "label": "中区间上限",
                    "default": "860",
                    "pipeline_type": "int"
                },
                {
                    "name": "MidWeight",
                    "label": "中区间权重",
                    "default": "3",
                    "pipeline_type": "int"
                },
                {
                    "name": "HighEnabled",
                    "label": "高区间启用(1/0)",
                    "default": "1",
                    "pipeline_type": "int"
                },
                {
                    "name": "HighMin",
                    "label": "高区间下限",
                    "default": "860",
                    "pipeline_type": "int"
                },
                {
                    "name": "HighMax",
                    "label": "高区间上限",
                    "default": "880",
                    "pipeline_type": "int"
                },
                {
                    "name": "HighWeight",
                    "label": "高区间权重",
                    "default": "1",
                    "pipeline_type": "int"
                },
                {
                    "name": "ConfirmTarget",
                    "label": "确认区域中心点[x,y](720p)",
                    "default": "[1088, 622]",
                    "pipeline_type": "string"
                },
                {
                    "name": "SecondConfirmTarget",
                    "label": "二次确认区域中心点[x,y](720p)",
                    "default": "[815, 467]",
                    "pipeline_type": "string"
                },
                {
                    "name": "ExitTarget",
                    "label": "退出区域中心点[x,y](720p)",
                    "default": "[649, 630]",
                    "pipeline_type": "string"
                },
                {
                    "name": "RefreshTarget",
                    "label": "刷新区域中心点[x,y](720p)",
                    "default": "[917, 117]",
                    "pipeline_type": "string"
                }
            ],
            "pipeline_override": {
                "CountdownMonitor": {
                    "recognition": {
                        "param": {
                            "custom_recognition_param": {
                                "refresh_target": "{RefreshTarget}"
                            }
                        }
                    }
                },
                "Purchase": {
                    "action": {
                        "param": {
                            "custom_action_param": {
                                "target_time": "{TargetTime}",
                                "jump_time_enabled": "{JumpTimeEnabled}",
                                "fixed_enabled": "{FixedEnabled}",
                                "fixed_delay": "{FixedDelay}",
                                "ultra_low_enabled": "{UltraLowEnabled}",
                                "ultra_low_min": "{UltraLowMin}",
                                "ultra_low_max": "{UltraLowMax}",
                                "ultra_low_weight": "{UltraLowWeight}",
                                "low_enabled": "{LowEnabled}",
                                "low_min": "{LowMin}",
                                "low_max": "{LowMax}",
                                "low_weight": "{LowWeight}",
                                "mid_enabled": "{MidEnabled}",
                                "mid_min": "{MidMin}",
                                "mid_max": "{MidMax}",
                                "mid_weight": "{MidWeight}",
                                "high_enabled": "{HighEnabled}",
                                "high_min": "{HighMin}",
                                "high_max": "{HighMax}",
                                "high_weight": "{HighWeight}",
                                "confirm_target": "{ConfirmTarget}",
                                "second_confirm_target": "{SecondConfirmTarget}",
                                "exit_target": "{ExitTarget}",
                                "refresh_target": "{RefreshTarget}"
                            }
                        }
                    }
                }
            }
        }
    }
}